datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

// Projects portfolio
model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  titleEn     String
  titleAr     String
  descriptionEn String
  descriptionAr String
  category    String   // "water-treatment" | "sewage-treatment" | "hvac" | "fire-fighting" | "civil" | "electromechanical"
  capacity    String?  // e.g., "500 m³/day"
  duration    String?  // e.g., "8 months"
  status      String   @default("completed") // "completed" | "in-progress" | "planned"
  clientName  String?
  location    String?
  year        Int?
  thumbnail   String?
  images      String   // JSON array of image URLs
  techSpecs   String?  // JSON object for technical specifications
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Services
model Service {
  id          String   @id @default(cuid())
  slug        String   @unique
  titleEn     String
  titleAr     String
  descriptionEn String
  descriptionAr String
  iconName    String   // Lucide icon name
  features    String   // JSON array of feature strings
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
}

// Testimonials
model Testimonial {
  id          String   @id @default(cuid())
  quoteEn     String?
  quoteAr     String
  authorName  String
  authorTitle String   // e.g., "Colonel Nasser Fared Salem"
  authorRoleEn String
  authorRoleAr String
  organization String?
  projectType String?
  rating      Int      @default(5)
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

// Contact form submissions (leads)
model ContactMessage {
  id          String   @id @default(cuid())
  fullName    String
  email       String
  phone       String?
  company     String?
  serviceInterest String?
  projectType String?
  budgetRange String?
  timeline    String?
  message     String
  fileName    String?
  fileSize    Int?
  status      String   @default("new") // "new" | "read" | "replied" | "archived"
  createdAt   DateTime @default(now())
}

// Client/Partner logos
model Client {
  id          String   @id @default(cuid())
  name        String
  logoUrl     String?
  type        String   @default("client") // "client" | "partner" | "supplier"
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
}

// Site settings (key-value store for editable content)
model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  type  String @default("text") // "text" | "json" | "number" | "boolean"
}
